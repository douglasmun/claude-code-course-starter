{
  "permissions": {
    "allow": [
      "Read",
      "Edit(src/**/*.ts)",
      "Edit(__tests__/**/*.ts)",
      "Write(src/**/*.ts)",
      "Write(__tests__/**/*.ts)",
      "Bash(npm test *)",
      "Bash(npm run format *)",
      "Bash(npm run build *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Edit(*.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write $CLAUDE_FILE_PATH 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -qE 'rm -rf|sudo|chmod 777' && echo 'BLOCKED: Destructive command' && exit 1 || exit 0"
          }
        ]
      }
    ]
  }
}
